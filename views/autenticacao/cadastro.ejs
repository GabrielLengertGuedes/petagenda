<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
  <main class="login-page d-flex align-items-center justify-content-center">
    <div class="register-card shadow-lg">
      <div class="register-wrapper">
        <div class="brand mb-4">
          <span class="brand-icon">🐾</span>
          <span class="brand-text">PetAgenda</span>
        </div>

        <h1 class="register-title">Cadastre-se</h1>
        <p class="login-subtitle">Informe seus dados:</p>

        <% if (erro) { %>
          <div class="alert alert-danger py-2"><%= erro %></div>
        <% } %>

        <% if (sucesso) { %>
          <div class="alert alert-success py-2"><%= sucesso %></div>
        <% } %>

        <form action="/cadastro" method="POST" class="mt-3">
          <div class="mb-3">
            <label for="nome" class="form-label">Nome completo:</label>
            <input
              type="text"
              class="form-control custom-input"
              id="nome"
              name="nome"
              value="<%= dados?.nome || '' %>"
              required
            >
          </div>

          <div class="mb-3">
            <label for="email" class="form-label">Email:</label>
            <input
              type="email"
              class="form-control custom-input"
              id="email"
              name="email"
              value="<%= dados?.email || '' %>"
              required
            >
          </div>

          <div class="mb-3">
            <label for="telefone" class="form-label">Telefone:</label>
            <input
              type="text"
              class="form-control custom-input"
              id="telefone"
              name="telefone"
              value="<%= dados?.telefone || '' %>"
              required
            >
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="senha" class="form-label">Senha:</label>
              <input
                type="password"
                class="form-control custom-input"
                id="senha"
                name="senha"
                required
              >
            </div>

            <div class="col-md-6 mb-3">
              <label for="confirmarSenha" class="form-label">Confirmar senha:</label>
              <input
                type="password"
                class="form-control custom-input"
                id="confirmarSenha"
                name="confirmarSenha"
                required
              >
            </div>
          </div>

          <button type="submit" class="btn login-btn w-100 mt-2">
            Cadastrar
          </button>

          <div class="mt-3 text-center">
            <a href="/login" class="small-link">Já tenho cadastro</a>
          </div>
        </form>
      </div>
    </div>
  </main>
</body>
</html>